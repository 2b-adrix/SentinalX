<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer Targeting Brackets (Cyber-Detection) -->
    <path
        android:pathData="M30,20 L20,20 L20,30 M78,20 L88,20 L88,30 M30,88 L20,88 L20,78 M78,88 L88,88 L88,78"
        android:strokeWidth="1.5"
        android:strokeLineCap="square"
        android:strokeColor="#38BDF8"
        android:strokeAlpha="0.4" />

    <!-- Heuristic Data Ring (Dotted Outer) -->
    <path
        android:pathData="M54,54 m-38,0 a38,38 0 1,1 76,0 a38,38 0 1,1 -76,0"
        android:strokeWidth="1"
        android:strokeColor="#2563EB"
        android:strokeAlpha="0.2"
        android:strokeDashArray="2,4" />

    <!-- Fragmented Hex-Shield (The Sentinel Perimeter) -->
    <path
        android:pathData="M54,22 L82,38 V70 L54,86 L26,70 V38 Z"
        android:strokeWidth="0.5"
        android:strokeColor="#60A5FA"
        android:strokeAlpha="0.3" />

    <!-- Pulse Wave 1 -->
    <path
        android:pathData="M54,54 m-28,0 a28,28 0 1,1 56,0 a28,28 0 1,1 -56,0"
        android:strokeWidth="0.8"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.15" />

    <!-- The Sentinel 'X' - Primary Neon Core -->
    <path
        android:pathData="M40,40 L68,68 M68,40 L40,68"
        android:strokeWidth="8"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="20"
                android:type="radial">
                <item android:color="#FFFFFF" android:offset="0.0" />
                <item android:color="#3B82F6" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glowing Aura for 'X' -->
    <path
        android:pathData="M40,40 L68,68 M68,40 L40,68"
        android:strokeWidth="12"
        android:strokeLineCap="round"
        android:strokeColor="#2563EB"
        android:strokeAlpha="0.25" />

    <!-- Inner Core Hub -->
    <path
        android:pathData="M54,54 m-6,0 a6,6 0 1,1 12,0 a6,6 0 1,1 -12,0"
        android:fillColor="#FFFFFF" />
    <path
        android:pathData="M54,54 m-10,0 a10,10 0 1,1 20,0 a10,10 0 1,1 -20,0"
        android:fillColor="#3B82F6"
        android:fillAlpha="0.3" />

    <!-- Vertical Scanning Laser (Subtle) -->
    <path
        android:pathData="M35,54 L73,54"
        android:strokeWidth="0.5"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.6" />

    <!-- Top Reflective Glint -->
    <path
        android:pathData="M45,35 L65,35"
        android:strokeWidth="1"
        android:strokeLineCap="round"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.2" />

</vector>
