<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- The Sentinel Shield -->
    <path
        android:pathData="M54,18 L84,30 C84,30 84,65 54,85 C24,65 24,30 24,30 L54,18 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endX="84"
                android:endY="85"
                android:startX="24"
                android:startY="18"
                android:type="linear">
                <item android:color="#2563EB" android:offset="0.0" /> <!-- Blue 600 -->
                <item android:color="#1E40AF" android:offset="1.0" /> <!-- Blue 800 -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner Shield Glow -->
    <path
        android:pathData="M54,24 L78,34 C78,34 78,60 54,78 C30,60 30,34 30,34 L54,24 Z"
        android:fillColor="#3B82F6" /> <!-- Blue 500 -->

    <!-- The "X" Sentinel Mark -->
    <path
        android:pathData="M44,40 L64,60 M64,40 L44,60"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:strokeColor="#FFFFFF" />

    <!-- Pulse/Heuristic Circle -->
    <path
        android:pathData="M54,50 m-22,0 a22,22 0 1,1 44,0 a22,22 0 1,1 -44,0"
        android:strokeWidth="1.5"
        android:strokeColor="#60A5FA"
        android:strokeAlpha="0.4" />

    <!-- Scanning Line (Subtle) -->
    <path
        android:pathData="M30,50 L78,50"
        android:strokeWidth="0.5"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.3" />

</vector>
