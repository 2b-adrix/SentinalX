<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Premium Nexus Sentinel Brand Icon (Optimized for App Icon) -->

    <!-- Top Glass Segment -->
    <path
        android:pathData="M54,18 L70,25 L54,32 L38,25 Z"
        android:fillColor="#3B82F6"
        android:fillAlpha="0.15"
        android:strokeWidth="0.5"
        android:strokeColor="#60A5FA"
        android:strokeAlpha="0.4" />

    <!-- Left Armored Plate -->
    <path
        android:pathData="M35,30 L50,38 V62 L32,72 V38 Z"
        android:fillColor="#1E293B"
        android:fillAlpha="0.5"
        android:strokeWidth="1"
        android:strokeColor="#3B82F6"
        android:strokeAlpha="0.6" />

    <!-- Right Armored Plate -->
    <path
        android:pathData="M73,30 L58,38 V62 L76,72 V38 Z"
        android:fillColor="#1E293B"
        android:fillAlpha="0.7"
        android:strokeWidth="1"
        android:strokeColor="#3B82F6"
        android:strokeAlpha="0.8" />

    <!-- Core Energy Pulse (Backglow) -->
    <path
        android:pathData="M48,42 L60,54 M60,42 L48,54"
        android:strokeWidth="12"
        android:strokeLineCap="round"
        android:strokeColor="#2563EB"
        android:strokeAlpha="0.15" />

    <!-- Central Neon 'X' -->
    <path
        android:pathData="M48,42 L60,54 M60,42 L48,54"
        android:strokeWidth="5"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:centerX="54"
                android:centerY="48"
                android:gradientRadius="12"
                android:type="radial">
                <item android:color="#FFFFFF" android:offset="0.0" />
                <item android:color="#60A5FA" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Precise Targeting Brackets -->
    <path
        android:pathData="M30,22 L22,22 L22,30 M86,22 L78,22 L78,30 M30,74 L22,74 L22,66 M86,74 L78,74 L78,66"
        android:strokeWidth="1.5"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.9" />

    <!-- Vertical Sentinel Alignment Line -->
    <path
        android:pathData="M54,25 V65"
        android:strokeWidth="0.3"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.3" />

    <!-- Brand Identity Tag (Subtle 'S' for Sentinel) -->
    <path
        android:pathData="M50,85 C50,85 58,82 58,88 C58,94 50,91 50,97 C50,103 58,100 58,100"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.2" />

</vector>
