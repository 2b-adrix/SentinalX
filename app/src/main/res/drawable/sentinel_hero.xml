                M198,228 l8,-18 h3.5 l8,18 h-3.8 l-1.8,-4.5 h-8.8 l-1.8,4.5 h-3.8 Z M204,221 h7.5 l-3.75,-9 Z
                M220,210 h3.5 v15.5 h10 v2.5 h-13.5 v-18 Z
                M238,208 l8,11 l8,-11 h4 l-10,14 l10,14 h-4 l-8,-11 l-8,11 h-4 l10,-14 l-10,-14 h4 Z
