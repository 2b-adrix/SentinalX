    android:width="400dp"
    android:height="300dp"
    android:viewportWidth="400"
    android:viewportHeight="300">

    <!-- Premium Brand Background: The Cyber Void -->
    <path android:pathData="M0,0h400v300h-400z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="200"
                android:centerY="150"
                android:gradientRadius="280"
                android:type="radial">
                <item android:color="#0F172A" android:offset="0.0" />
                <item android:color="#020617" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Digital Floor Horizon (Grounded Perspective) -->
    <path
        android:pathData="M0,240 L400,240 M0,255 L400,255 M0,275 L400,275 M0,300 L400,300 M100,230 L-50,300 M150,230 L100,300 M250,230 L300,300 M300,230 L450,300"
