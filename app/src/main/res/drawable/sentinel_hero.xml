            android:fillColor="#3B82F6"
            android:fillAlpha="0.1"
            android:strokeWidth="1"
            android:strokeColor="#60A5FA"
            android:strokeAlpha="0.3" />

        <!-- Left Wing Segment -->
        <path
            android:pathData="M150,85 L190,105 V155 L145,175 V105 Z"
            android:fillColor="#1E293B"
            android:fillAlpha="0.4"
            android:strokeWidth="1.5"
            android:strokeColor="#3B82F6"
            android:strokeAlpha="0.5" />

        <!-- Right Wing Segment -->
        <path
            android:pathData="M250,85 L210,105 V155 L255,175 V105 Z"
            android:fillColor="#1E293B"
            android:fillAlpha="0.6"
            android:strokeWidth="1.5"
            android:strokeColor="#3B82F6"
            android:strokeAlpha="0.7" />

        <!-- The Energy Core: Floating 'X' -->
        <!-- Core Depth Shadow -->
        <path
            android:pathData="M185,115 L215,145 M215,115 L185,145"
            android:strokeWidth="20"
            android:strokeLineCap="round"
            android:strokeColor="#2563EB"
            android:strokeAlpha="0.1" />

        <!-- Neon Primary X -->
        <path
            android:pathData="M185,115 L215,145 M215,115 L185,145"
            android:strokeWidth="8"
            android:strokeLineCap="round">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:centerX="200"
                    android:centerY="130"
                    android:gradientRadius="25"
                    android:type="radial">
                    <item android:color="#FFFFFF" android:offset="0.0" />
                    <item android:color="#60A5FA" android:offset="1.0" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Precision Brackets (Integrated with wings) -->
        <path
            android:pathData="M140,80 L130,80 L130,95 M270,80 L260,80 L260,95 M140,180 L130,180 L130,165 M270,180 L260,180 L260,165"
            android:strokeWidth="2"
            android:strokeColor="#FFFFFF"
            android:strokeAlpha="0.8" />

        <!-- Sentinel Vertical Laser Line -->
        <path
            android:pathData="M200,70 V165"
            android:strokeWidth="0.5"
            android:strokeColor="#FFFFFF"
            android:strokeAlpha="0.2" />
