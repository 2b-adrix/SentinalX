        <!-- Sub-Brand Tagline: NEURAL RISK SHIELD -->
        <path
            android:fillColor="#60A5FA"
            android:fillAlpha="0.6"
            android:pathData="
                M135,235 h1.5 v4 h2 v1 h-3.5 v-5 Z
                M142,235 h3 v1 h-2 v1 h1.5 v1 h-1.5 v1 h2 v1 h-3 v-5 Z
                M148,235 v3 c0,1 1,1 1,1 s1,0 1,-1 v-3 h1.5 v3 c0,2 -2.5,2 -2.5,2 s-2.5,0 -2.5,-2 v-3 h1.5 Z
                M156,235 h2.5 c1,0 1.5,0.5 1.5,1 s-0.5,1 -1.5,1 h-1 v2 h-1.5 v-5 Z M157.5,236.5 h1 v1 h-1 v-1 Z
