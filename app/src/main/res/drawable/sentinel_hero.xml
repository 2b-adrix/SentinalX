        android:strokeColor="#1E293B"
        android:strokeAlpha="0.6" />

    <!-- Ambient Sentinel Glow (Pulse Center) -->
    <path
        android:pathData="M200,120m-120,0a120,120 0 1,1 240,0a120,120 0 1,1 -240,0"
        android:fillAlpha="0.04">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="200"
                android:centerY="120"
                android:gradientRadius="140"
                android:type="radial">
                <item android:color="#3B82F6" android:offset="0.0" />
